# sift configuration
# Default location: <vault-root>/vault-ingest.yaml
# To put it elsewhere (e.g. a hidden sub-folder for Obsidian users), use:
#   sift init <vault> --config <vault>/.config/sift.yaml
# and then export SIFT_CONFIG=<vault>/.config/sift.yaml in your shell.

vault: ~/Documents/MyVault           # absolute path to vault root
raw_dir: raw                         # relative to vault, or absolute path
output_dir: captures                 # relative to vault, or absolute path
state_dir: .vault-ingest             # relative to vault, or absolute path; holds queue.db
raw_ttl_days: 7                      # raw files older than this are deleted on next run

# Tip: if your vault is on iCloud Drive, use absolute paths for raw_dir and state_dir
# to avoid iCloud blocking file operations in background processes:
#   raw_dir: /Users/you/.sift/raw
#   state_dir: /Users/you/.sift/state

enricher:
  # Two backends available:
  #
  # claude-cli — uses your Claude Code subscription, zero extra cost.
  #   Summarisation via `claude -p`. No API key needed.
  #   Vision/image captioning not supported; use openrouter for that.
  #
  # openrouter — pay-per-token via OpenRouter API (~$0.0001/clip with Gemini Flash Lite).
  #   Supports all media types including image captioning.

  backend: claude-cli                 # claude-cli | openrouter

  claude_cli:
    claude_bin: claude                # full path if `claude` is not in PATH
    whisper_svc_url: http://localhost:8742

  openrouter:
    api_key_env: OPENROUTER_API_KEY
    model_text: google/gemini-2.5-flash-lite
    model_vision: google/gemini-2.5-flash
    whisper_svc_url: http://localhost:8742

  monthly_budget_usd: 10             # optional; only applies to openrouter backend

extractors:
  yt_dlp_auto_upgrade: true

private_caption_keywords:
  - private
  - internal
  - confidential
