+_URL_RE = re.compile(r'^https?://\S+$')
+
+
+def _is_bare_url(text: str) -> bool:
+    return bool(_URL_RE.match(text.strip()))
+
+
+def _enqueue_sift(url: str, chat_id: str, thread_id):
+    ts = datetime.datetime.now().strftime("%Y%m%dT%H%M%S")
+    Path(SIFT_QUEUE_DIR).mkdir(parents=True, exist_ok=True)
+    entry = {"url": url, "chat_id": chat_id, "ts": ts}
+    fname = f"{ts}-{secrets.token_hex(3)}.json"
+    Path(SIFT_QUEUE_DIR, fname).write_text(json.dumps(entry))
+    send("⏳ sifting…", chat_id=chat_id, thread_id=thread_id)
+
